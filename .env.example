# Contact form email delivery (Resend). Without these the form still works in
# dev and logs the submission to the server console instead of sending.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@trustcodesystem.tech
CONTACT_FROM_EMAIL=TrustCode <onboarding@resend.dev>

# Optional production rate limiting for /api/contact. Configure these with an
# Upstash Redis REST database so limits are shared across serverless instances.
# Without them, local/dev falls back to an in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
